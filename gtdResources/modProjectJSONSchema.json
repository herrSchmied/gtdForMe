{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MOD-Project",
    "description": "A Project",
    "type": "object",
    "properties": 
	{
        "Project_Name": 
		{
            "description": "A unique name for the Project",
            "type": "string"
        },
        "Project_Status":
		{
            "description": "Status of Project",
            "type": "string",
			"const":  "Maybe_One_Day?"
        },
        "Goal":
		{
			"description": "Goal of the Project",
            "type": "string"
        },
		"NDT_of_Project":
		{
			"description": "Noted Date Time. Project written here Datetime",
			"type": "string",
			"pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}\\s[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}$"
		},
		"DLDT_of_Project":
		{
			"description": "Deadline Date Time",
			"type": "string",
			"const": "UNKNOWN"
		}
    },
    "required": ["Project_Name", "Project_Status", "Goal", "NDT_of_Project", "DLDT_of_Project"]
	}